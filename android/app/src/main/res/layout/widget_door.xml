<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/door_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container_bg"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <!-- 门锁图标 -->
    <FrameLayout
        android:id="@+id/door_widget_icon_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/widget_icon_bg">

            <ImageView
                android:id="@+id/door_widget_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:adjustViewBounds="true"
                android:layout_gravity="center"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_lock_outline"
                android:contentDescription="@string/door_widget_name" />
        </FrameLayout>
    </FrameLayout>

    <!-- 状态区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/door_widget_door_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:maxLines="1"
            android:maxWidth="120dp"
            android:minWidth="70dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/widget_chip_gray"
            android:text="待开门"
            android:textColor="@color/widget_gray"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center" />

        <TextView
            android:id="@+id/door_widget_device_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="3dp"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:maxLines="1"
            android:maxWidth="120dp"
            android:minWidth="70dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/widget_chip_green"
            android:text="设备在线"
            android:textColor="@color/widget_success"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center" />

        <TextView
            android:id="@+id/door_widget_wifi_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="3dp"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:maxLines="1"
            android:maxWidth="120dp"
            android:minWidth="70dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/widget_chip_yellow"
            android:text="WiFi：非配置"
            android:textColor="@color/widget_warning"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center" />

        <TextView
            android:id="@+id/door_widget_mqtt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="3dp"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:maxLines="1"
            android:maxWidth="120dp"
            android:minWidth="70dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/widget_chip_gray"
            android:text="MQTT：未连接"
            android:textColor="@color/widget_gray"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
