<?xml version="1.0" encoding="utf-8"?>
<!-- 课表组件预览布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的课表"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="&lt;"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周一 · 第1周"
                android:textColor="#666666"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="&gt;"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 示例课程列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 示例课程1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_course_item_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="4dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="false"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_course_indicator_mask"
                android:tint="#BBDEFB" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="高等数学"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="08:30-10:05 · 教一101"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1-2节"
                android:textColor="#999999"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 示例课程2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_course_item_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="4dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="false"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_course_indicator_mask"
                android:tint="#C8E6C9" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="大学英语"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="10:35-12:10 · 教二203"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3-4节"
                android:textColor="#999999"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
