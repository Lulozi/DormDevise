<?xml version="1.0" encoding="utf-8"?>
<!-- 2x2/4x2 课表组件布局：显示今日课程列表 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/course_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container_bg">

    <!-- 可见内容层（保持原有视觉） -->
    <LinearLayout
        android:id="@+id/course_widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/course_widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="今日课程"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/course_widget_prev_day_anchor"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|start"
                        android:background="@android:color/transparent">

                        <TextView
                            android:id="@+id/course_widget_prev_day"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="&lt;"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/course_widget_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:text="周一 · 第1周"
                        android:textColor="#666666"
                        android:textSize="11sp" />

                    <FrameLayout
                        android:id="@+id/course_widget_next_day_anchor"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="2dp"
                        android:background="@android:color/transparent">

                        <TextView
                            android:id="@+id/course_widget_next_day"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="&gt;"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/course_widget_prev_day_hit"
                    android:layout_width="64dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="-10dp"
                    android:layout_marginStart="-12dp"
                    android:background="@android:color/transparent" />

                <FrameLayout
                    android:id="@+id/course_widget_next_day_hit"
                    android:layout_width="64dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-10dp"
                    android:layout_marginEnd="-22dp"
                    android:background="@android:color/transparent" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/course_widget_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cacheColorHint="@android:color/transparent"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="4dp"
                android:paddingBottom="2dp"
                android:scrollbars="none" />

            <LinearLayout
                android:id="@+id/course_widget_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/course_widget_empty"
                    android:src="@drawable/ic_schedule_empty"
                    android:tint="#CCCCCC" />

                <TextView
                    android:id="@+id/course_widget_empty_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/course_widget_empty"
                    android:textColor="#999999"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
