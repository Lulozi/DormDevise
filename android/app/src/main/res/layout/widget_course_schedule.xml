<?xml version="1.0" encoding="utf-8"?>
<!-- 2x2/4x2 课表组件布局：显示今日课程列表 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/course_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/course_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日课程"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/course_widget_prev_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="&lt;"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/course_widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周一 · 第1周"
                android:textColor="#666666"
                android:textSize="11sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/course_widget_next_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="&gt;"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/course_widget_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:cacheColorHint="@android:color/transparent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:paddingBottom="2dp"
            android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/course_widget_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_schedule_empty"
                android:tint="#CCCCCC"
                android:contentDescription="@string/course_widget_empty" />

            <TextView
                android:id="@+id/course_widget_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/course_widget_empty"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
